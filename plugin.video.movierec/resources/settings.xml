<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings version="1">
    <section id="movierec" label="30000">
        <category id="server" label="30001">
            <group id="1" label="30004">
                <setting id="server_url" type="string" label="30010">
                    <level>0</level>
                    <default>https://movierec.eulerai.net</default>
                    <control type="edit" format="string">
                        <heading>30010</heading>
                    </control>
                </setting>
                <setting id="server_password" type="string" label="30011">
                    <level>0</level>
                    <default>changeme</default>
                    <control type="edit" format="string">
                        <heading>30011</heading>
                    </control>
                </setting>
            </group>
        </category>
        <category id="playback" label="30002">
            <group id="1" label="30005">
                <setting id="quality_pref" type="string" label="30012">
                    <level>0</level>
                    <default>auto</default>
                    <constraints>
                        <options>
                            <option label="30100">auto</option>
                            <option label="30101">4K</option>
                            <option label="30102">1080p</option>
                            <option label="30103">720p</option>
                        </options>
                    </constraints>
                    <control type="list" format="string"/>
                </setting>
                <setting id="subtitle_languages" type="string" label="30013">
                    <level>0</level>
                    <default>en</default>
                    <control type="edit" format="string">
                        <heading>30013</heading>
                    </control>
                </setting>
                <setting id="scrobble_enabled" type="boolean" label="30014">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="autoplay_next_episode" type="boolean" label="30016">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="anime_audio_jpn" type="boolean" label="30017">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="auto_english_subs" type="boolean" label="30018">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>
        <category id="advanced" label="30003">
            <group id="1" label="30006">
                <setting id="page_size" type="integer" label="30015">
                    <level>0</level>
                    <default>40</default>
                    <constraints>
                        <minimum>10</minimum>
                        <maximum>100</maximum>
                        <step>5</step>
                    </constraints>
                    <control type="slider" format="integer"/>
                </setting>
            </group>
            <!-- Hidden schema-only keys required by the vendored Otaku
                 scrapers (resources/lib/otaku_scrapers/). Kodi 21+
                 strictly validates settings READS against the schema,
                 not just writes — undeclared keys raise TypeError. So
                 we declare every key any vendored Otaku module reads
                 or writes, all at level=4 (hidden) with Otaku's own
                 defaults. Never edit these from the addon UI — the
                 settings have no meaningful effect for our use case
                 since we don't surface Otaku's browse/playback UI.

                 The list comes from grepping the vendored otaku_scrapers
                 tree for control.(get|set)*(...) literal-key calls. -->
            <group id="2" label="30099">
                <!-- booleans -->
                <setting id="artwork.clearlogo" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="artwork.fanart" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="best_match" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="context.otaku.fanartselect" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="divflavors.dubonly" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="divflavors.showdub" type="boolean"><level>4</level><default>true</default><control type="toggle"/></setting>
                <setting id="fs_enable" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="general.smart.scroll.enable" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="interface.viewidswitch" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="interface.viewtype" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="provider.animixalt" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="provider.hianimealt" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <setting id="widget.hide.nextpage" type="boolean"><level>4</level><default>false</default><control type="toggle"/></setting>
                <!-- integers -->
                <setting id="fs_timeout" type="integer"><level>4</level><default>20</default><control type="edit" format="integer"/></setting>
                <setting id="general.fuzzy" type="integer"><level>4</level><default>0</default><control type="edit" format="integer"/></setting>
                <setting id="general.source" type="integer"><level>4</level><default>0</default><control type="edit" format="integer"/></setting>
                <setting id="interface.addon.view.id" type="integer"><level>4</level><default>50</default><control type="edit" format="integer"/></setting>
                <setting id="interface.episode.view.id" type="integer"><level>4</level><default>50</default><control type="edit" format="integer"/></setting>
                <setting id="interface.show.view.id" type="integer"><level>4</level><default>50</default><control type="edit" format="integer"/></setting>
                <setting id="widgets.delay" type="integer"><level>4</level><default>0</default><control type="edit" format="integer"/></setting>
                <!-- strings -->
                <setting id="format" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="fs_url" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="interface.addon.view" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="interface.episode.view" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="interface.icons" type="string"><level>4</level><default>default</default><control type="edit" format="string"/></setting>
                <setting id="interface.show.view" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="reuselanguageinvoker.status" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="version" type="string"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <!-- list[string] -->
                <setting id="embed.config" type="list[string]"><level>4</level><default>doodstream|filelions|filemoon|hd-1|hd-2|hd-3|iga|kwik|megacloud|megaf|moonf|mp4upload|mp4u|mycloud|noads|noadsalt|swish|streamtape|streamwish|t-cloud|vidcdn|vidhide|vidplay|vidsrc|vidstream|yourupload|zto</default><control type="edit" format="string"/></setting>
                <setting id="fanart.mal_ids" type="list[string]"><level>4</level><default></default><control type="edit" format="string"/></setting>
                <setting id="fanart.selections" type="list[string]"><level>4</level><default></default><control type="edit" format="string"/></setting>
            </group>
        </category>
    </section>
</settings>
