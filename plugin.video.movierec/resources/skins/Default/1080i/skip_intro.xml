<?xml version="1.0" encoding="UTF-8"?>
<window>
	<!-- Non-modal popup shown by SkipIntro Python class during the intro
	     window of an anime episode. doModal() captures remote input; the
	     bottom-right placement keeps the video visible. Default focus on
	     3001 so Enter immediately skips. -->
	<defaultcontrol always="true">3001</defaultcontrol>
	<onload>Dialog.Close(fullscreeninfo,true)</onload>
	<onload>Dialog.Close(videoosd,true)</onload>
	<onload>SetFocus(3001)</onload>
	<controls>
		<control type="group">
			<animation type="WindowOpen" reversible="false">
				<effect type="fade" start="0" end="100" time="250"/>
				<effect type="slide" start="600,0" end="0,0" time="300"/>
			</animation>
			<animation type="WindowClose" reversible="false">
				<effect type="fade" start="100" end="0" time="200"/>
				<effect type="slide" start="0,0" end="600,0" time="250"/>
			</animation>
			<control type="group">
				<right>60</right>
				<bottom>160</bottom>
				<width>460</width>
				<height>88</height>
				<!-- Solid black background (fully opaque) -->
				<control type="image">
					<width>100%</width>
					<height>100%</height>
					<texture border="2" colordiffuse="FF0E0E0E">white.png</texture>
				</control>
				<!-- 2px white border around the panel for visibility on bright art -->
				<control type="image">
					<width>100%</width>
					<height>2</height>
					<texture colordiffuse="FFFFFFFF">white.png</texture>
				</control>
				<control type="image">
					<top>86</top>
					<width>100%</width>
					<height>2</height>
					<texture colordiffuse="FFFFFFFF">white.png</texture>
				</control>
				<control type="image">
					<width>2</width>
					<height>100%</height>
					<texture colordiffuse="FFFFFFFF">white.png</texture>
				</control>
				<control type="image">
					<left>458</left>
					<width>2</width>
					<height>100%</height>
					<texture colordiffuse="FFFFFFFF">white.png</texture>
				</control>
				<!-- Buttons -->
				<control type="grouplist">
					<orientation>horizontal</orientation>
					<top>12</top>
					<left>14</left>
					<height>64</height>
					<width>432</width>
					<itemgap>10</itemgap>
					<control type="button" id="3001">
						<label>Skip Intro</label>
						<height>64</height>
						<width>280</width>
						<font>font13</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FFFFFFFF</focusedcolor>
						<align>center</align>
						<aligny>center</aligny>
						<texturefocus border="4" colordiffuse="FF1E88E5">white.png</texturefocus>
						<texturenofocus border="4" colordiffuse="FF2962FF">white.png</texturenofocus>
						<pulseonselect>no</pulseonselect>
						<onleft>3002</onleft>
						<onright>3002</onright>
					</control>
					<control type="button" id="3002">
						<label>Close</label>
						<height>64</height>
						<width>140</width>
						<font>font13</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FFFFFFFF</focusedcolor>
						<align>center</align>
						<aligny>center</aligny>
						<texturefocus border="4" colordiffuse="FF888888">white.png</texturefocus>
						<texturenofocus border="4" colordiffuse="FF3A3A3A">white.png</texturenofocus>
						<pulseonselect>no</pulseonselect>
						<onleft>3001</onleft>
						<onright>3001</onright>
					</control>
				</control>
			</control>
		</control>
	</controls>
</window>
